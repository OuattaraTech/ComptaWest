# ── Serveur ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Base de données PostgreSQL ───────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=comptawest
DB_USER=comptawest_user
DB_PASSWORD=remplacer_par_votre_mot_de_passe_db
# SSL : mettre DB_SSL=true en production si la base est managée/distante.
# DB_SSL_REJECT_UNAUTHORIZED=false uniquement si certificat auto-signé.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Pool de connexions PostgreSQL ────────────────────────────────────
# Taille MAX du pool par worker Node. En mode cluster pm2 (N workers),
# le total de connexions ouvertes côté PG = N × DB_POOL_MAX.
# Vérifier que `max_connections` PostgreSQL ≥ N × DB_POOL_MAX + 20 (admin).
#
# Recommandations :
#   - VPS 1-2 CPU, 1 worker : DB_POOL_MAX=20-30
#   - VPS 4 CPU, 4 workers  : DB_POOL_MAX=20 (total 80) sur PG max=100
#   - K8s + PgBouncer       : DB_POOL_MAX=5-10 par worker (PgBouncer
#                             agrège vers PG)
DB_POOL_MAX=50
DB_POOL_IDLE_MS=10000
DB_POOL_TIMEOUT_MS=5000

# ── Cluster pm2 (production uniquement) ──────────────────────────────
# Nombre d'instances Node.js lancées en parallèle. 'max' = un par CPU.
# Défini ici à titre indicatif, lu par ecosystem.config.js.
PM2_INSTANCES=max

# ── JWT (authentification) ───────────────────────
# OBLIGATOIRE : 32 caractères minimum. Générez une clé unique par environnement :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Ne réutilisez JAMAIS la même clé entre dev et production.
JWT_SECRET=remplacer_par_une_cle_generee_aleatoirement
JWT_EXPIRES_IN=7d

# ── URLs publiques (CORS + liens dans les emails) ────────────────────
# En production, toutes ces URLs doivent pointer vers le domaine officiel
# useapex.ci (réservé le 2026-05-29). En dev, garder les valeurs locales.
#
# FRONTEND_URL  : origine autorisée par CORS et utilisée comme base pour
#                 les liens dans les emails (invitations, activations…).
# PUBLIC_URL    : URL canonique de la landing (utilisée dans les emails
#                 d'annonce, les liens "voir sur le web", etc.).
# BACKEND_BASE_URL  : URL publique de l'API (webhooks Wave/Orange/MTN,
#                     callbacks FNE, retours de paiement).
# FRONTEND_BASE_URL : URL publique de l'app (success_url/error_url
#                     des paiements Mobile Money).
#
# Production recommandée :
#   FRONTEND_URL=https://app.useapex.ci
#   PUBLIC_URL=https://useapex.ci
#   BACKEND_BASE_URL=https://api.useapex.ci
#   FRONTEND_BASE_URL=https://app.useapex.ci
FRONTEND_URL=http://localhost:5173
PUBLIC_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:5173

# ── Envoi d'emails transactionnels (Resend) ──────────────────────────
# Utilisé par :
#   - Invitations cabinets envoyées depuis /admin (super-admin)
#   - Invitations PME envoyées depuis le portail cabinet partenaire
#   - Relances automatiques J+2 sur invitations PME pending
#   - Emails d'activation après validation d'une candidature cabinet
#
# Sans clé : le système continue de fonctionner mais les emails ne
# partent pas — les liens d'activation restent copiables manuellement
# depuis la console admin, et les liens WhatsApp wa.me restent générés.
#
# Obtention (gratuit, 100 emails/jour, 3 000/mois) :
#   1. Créer un compte sur https://resend.com (Google/GitHub OK)
#   2. Vérifier ton domaine (Add Domain → ajouter les DNS TXT/CNAME
#      retournés chez ton registrar — propagation 5-30 min)
#   3. API Keys → Create API Key → permission « Sending access »
#   4. Coller la clé (commence par re_) ci-dessous
#
# En dev sans domaine vérifié : Resend autorise l'envoi UNIQUEMENT vers
# l'email du compte créateur. Pour tester l'envoi vers d'autres adresses,
# il faut vérifier un domaine.
RESEND_API_KEY=

# Adresse expéditeur affichée dans les emails. Doit utiliser un domaine
# vérifié dans Resend. Format : "Nom Affiché <email@domaine.ci>".
# En prod : "ApeX <noreply@useapex.ci>" (après vérification DNS Resend).
# En dev sans domaine : utiliser onboarding@resend.dev (Resend par défaut).
EMAIL_FROM=ApeX <onboarding@resend.dev>

# Adresse de réponse (Reply-To) pour les emails transactionnels.
# Les utilisateurs qui répondent à un email automatique tombent ici.
EMAIL_REPLY_TO=support@useapex.ci

# Email de support affiché dans l'UI, les pieds de page d'emails et la
# landing publique. Doit pointer vers une boîte réellement relevée.
SUPPORT_EMAIL=support@useapex.ci

# ── Newsletter — synchro vers une Audience Resend ────────────────────
# Quand ces variables sont renseignées, chaque inscription/désinscription
# est reflétée dans l'audience Resend. Tu rédiges et envoies ensuite tes
# newsletters depuis Resend → Broadcasts (désinscription gérée par Resend).
# Laisser vide = synchro désactivée (les abonnés restent dans la table BD).
#
# ⚠️ La gestion des contacts d'audience exige une clé Resend en « Full
# access ». La clé d'envoi (RESEND_API_KEY) est souvent restreinte à
# « send emails » → créer une clé Full access dédiée ici (recommandé,
# garde la clé d'envoi à droits minimaux). À défaut, RESEND_API_KEY est
# utilisée et doit alors être en Full access.
RESEND_AUDIENCE_API_KEY=
# ID de l'audience par défaut (Resend → Audience → bouton </> → audienceId).
RESEND_AUDIENCE_ID=

# ── OCR (reconnaissance automatique des factures) ────────────────────
# Clé API Mistral utilisée par le scanner de pièces justificatives
# (modèle pixtral-12b). Une seule clé pour toute la plateforme :
# ApeX paie Mistral et refacture le service dans l'abonnement
# vendu au client final.
#
# Obtention : https://console.mistral.ai → API Keys → Create new key
# Tarif indicatif : ~0,15 USD / million de tokens (≈ 5 000-10 000
# tokens par facture scannée). Sans clé, le scanner fonctionne en
# mode démo et renvoie des données simulées.
MISTRAL_API_KEY=

# ── Paiement d'abonnement ApeX — agrégateur CinetPay ─────────────────
# CinetPay (société ivoirienne) couvre Wave, Orange Money, MTN MoMo,
# Moov et les cartes Visa/Mastercard via une seule API. Payouts FCFA
# directs sur le compte bancaire CI d'ApeX.
#
# Mode global :
#   mock  → simulation locale (page d'attente 3 s puis succès simulé,
#           aucun appel PSP externe — parfait pour dev et démos)
#   live  → appel réel CinetPay (retombe automatiquement en mock si
#           les clés ci-dessous sont absentes)
PAYMENT_MODE=mock

# CinetPay — https://cinetpay.com → Connexion → Intégration → Mes services
# Récupérer apikey + site_id (par site marchand) puis Secret Key (pour
# signer les webhooks). En test, créer un site sandbox.
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
