# ── Serveur ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Base de données PostgreSQL ───────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=comptawest
DB_USER=comptawest_user
DB_PASSWORD=remplacer_par_votre_mot_de_passe_db
# SSL : mettre DB_SSL=true en production si la base est managée/distante.
# DB_SSL_REJECT_UNAUTHORIZED=false uniquement si certificat auto-signé.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Pool de connexions PostgreSQL ────────────────────────────────────
# Taille MAX du pool par worker Node. En mode cluster pm2 (N workers),
# le total de connexions ouvertes côté PG = N × DB_POOL_MAX.
# Vérifier que `max_connections` PostgreSQL ≥ N × DB_POOL_MAX + 20 (admin).
#
# Recommandations :
#   - VPS 1-2 CPU, 1 worker : DB_POOL_MAX=20-30
#   - VPS 4 CPU, 4 workers  : DB_POOL_MAX=20 (total 80) sur PG max=100
#   - K8s + PgBouncer       : DB_POOL_MAX=5-10 par worker (PgBouncer
#                             agrège vers PG)
DB_POOL_MAX=50
DB_POOL_IDLE_MS=10000
DB_POOL_TIMEOUT_MS=5000

# ── Cluster pm2 (production uniquement) ──────────────────────────────
# Nombre d'instances Node.js lancées en parallèle. 'max' = un par CPU.
# Défini ici à titre indicatif, lu par ecosystem.config.js.
PM2_INSTANCES=max

# ── JWT (authentification) ───────────────────────
# OBLIGATOIRE : 32 caractères minimum. Générez une clé unique par environnement :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Ne réutilisez JAMAIS la même clé entre dev et production.
JWT_SECRET=remplacer_par_une_cle_generee_aleatoirement
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────
# URL du frontend autorisée à appeler l'API (obligatoire en production).
FRONTEND_URL=http://localhost:5173

# ── Envoi d'emails transactionnels (Resend) ──────────────────────────
# Utilisé par :
#   - Invitations cabinets envoyées depuis /admin (super-admin)
#   - Invitations PME envoyées depuis le portail cabinet partenaire
#   - Relances automatiques J+2 sur invitations PME pending
#   - Emails d'activation après validation d'une candidature cabinet
#
# Sans clé : le système continue de fonctionner mais les emails ne
# partent pas — les liens d'activation restent copiables manuellement
# depuis la console admin, et les liens WhatsApp wa.me restent générés.
#
# Obtention (gratuit, 100 emails/jour, 3 000/mois) :
#   1. Créer un compte sur https://resend.com (Google/GitHub OK)
#   2. Vérifier ton domaine (Add Domain → ajouter les DNS TXT/CNAME
#      retournés chez ton registrar — propagation 5-30 min)
#   3. API Keys → Create API Key → permission « Sending access »
#   4. Coller la clé (commence par re_) ci-dessous
#
# En dev sans domaine vérifié : Resend autorise l'envoi UNIQUEMENT vers
# l'email du compte créateur. Pour tester l'envoi vers d'autres adresses,
# il faut vérifier un domaine.
RESEND_API_KEY=

# Adresse expéditeur affichée dans les emails. Doit utiliser un domaine
# vérifié dans Resend. Format : "Nom Affiché <email@domaine.ci>".
# En dev sans domaine : utiliser onboarding@resend.dev (Resend par défaut).
EMAIL_FROM=ApeX <onboarding@resend.dev>

# ── OCR (reconnaissance automatique des factures) ────────────────────
# Clé API Mistral utilisée par le scanner de pièces justificatives
# (modèle pixtral-12b). Une seule clé pour toute la plateforme :
# ApeX paie Mistral et refacture le service dans l'abonnement
# vendu au client final.
#
# Obtention : https://console.mistral.ai → API Keys → Create new key
# Tarif indicatif : ~0,15 USD / million de tokens (≈ 5 000-10 000
# tokens par facture scannée). Sans clé, le scanner fonctionne en
# mode démo et renvoie des données simulées.
MISTRAL_API_KEY=
