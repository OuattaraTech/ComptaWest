{
  "name": "apex-backend",
  "version": "2.1.0",
  "description": "API ApeX — Multi-entreprise, Dépenses, Taxes",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "predev": "fuser -k 5000/tcp 2>/dev/null || true",
    "dev": "nodemon src/index.js",
    "dev:test": "NODE_ENV=test nodemon src/index.js",
    "test": "NODE_ENV=test node --test --test-concurrency=1 tests/",
    "test:full": "NODE_ENV=test node --test --test-concurrency=1 tests/",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js status",
    "migrate:baseline": "node scripts/migrate.js baseline",
    "prod:start": "pm2 start ecosystem.config.js",
    "prod:reload": "pm2 reload ecosystem.config.js",
    "prod:stop": "pm2 stop apex-api",
    "prod:logs": "pm2 logs apex-api",
    "prod:status": "pm2 status",
    "prod:monit": "pm2 monit",
    "loadtest": "NODE_ENV=test node scripts/load-test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdfmake": "^0.3.8",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pm2": "^7.0.1"
  }
}
