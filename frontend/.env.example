# ── URL de l'API backend ─────────────────────────────────────────────
# En dev : laissé vide, /api est proxifié vers http://localhost:5000
#          par vite.config.js (cf. block "proxy").
# En prod : pointer vers le backend public, ex. https://api.useapex.ci/api
#          (ou https://app.useapex.ci/api si l'API est servie sous le
#          même hostname via Caddy).
VITE_API_URL=

# ── URL publique de la landing (CTA "Voir la landing") ───────────────
VITE_PUBLIC_URL=https://useapex.ci

# ── Email de support affiché dans l'UI ───────────────────────────────
VITE_SUPPORT_EMAIL=support@useapex.ci

# ── Sentry frontend (facultatif) ─────────────────────────────────────
# Si vide, Sentry n'est pas initialisé. À renseigner uniquement en prod.
VITE_SENTRY_DSN=
